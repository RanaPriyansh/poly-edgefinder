[Unit]
Description=Thielon Polymarket Data Collector
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/thielon-poly-edgefinder
Environment="PATH=/opt/thielon-poly-edgefinder/venv/bin"
EnvironmentFile=/opt/thielon-poly-edgefinder/.env
ExecStart=/opt/thielon-poly-edgefinder/venv/bin/python -m src.data_collectors.simmer_collector
Restart=on-failure
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target